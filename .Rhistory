###############################################################################
# MCS Record Data: Exploration & Summary
# ----------------------------------------
# This script handles wide-format maltreatment record data where 17 columns
# repeat up to 36 times (suffixes 1–36). It reshapes to long format and
# produces descriptive summaries and visualizations.
#
# Maltreatment subtypes:
#   PA  = Physical Abuse
#   SA  = Sexual Abuse
#   FTP = Failure to Protect
#   LS  = Lack of Supervision
#   EM  = Emotional Maltreatment
#   ML  = Medical/Legal (or similar)
#   ED  = Educational Neglect
###############################################################################
#library(dplyr)
#df1 <- read.csv("~/Dropbox/Macbook/Authored/Papers/CHS Type Paper/data/cm_cbcl_2025-12-02_26-43-35.csv")
df_wide <- read.csv("/Users/zacharyfisher/Dropbox/Macbook/Authored/Papers/CHS Type Paper/data/mcs_preV1_2025-11-12_40-15-29.csv")
df_wide <- df_wide %>% naniar::replace_with_na_all(condition = ~.x %in% c("REF", "MIS", "<NA>"))
# ===========================================================================
# 1. RESHAPE: WIDE → LONG
# ===========================================================================
# Strategy: pivot each 17-column block into one row per record per case.
# The suffix number (1–36) becomes `record_num`.
subtypes <- c("pa", "sa", "ftp", "los", "em", "ml", "edu")
# Build a specification for pivoting
reshape_to_long <- function(df, max_suffix = 36) {
all_rows <- list()
for (s in 1:max_suffix) {
# Column names for this suffix
date_col  <- paste0("mcs_rpt_date", s)
any_col   <- paste0("mcs_any_rcd", s)
perp_col  <- paste0("mcs_perp_rcd", s)
# Skip if the date column doesn't exist
if (!date_col %in% names(df)) next
# Build a small tibble for this suffix
rcd <- df %>%
select(g2id, all_of(date_col), all_of(any_col), all_of(perp_col),
matches(paste0("^mcs_(pa|sa|ftp|los|em|ml|edu)_(rcd|sev_rcd)", s, "$"))) %>%
mutate(record_num = s)
# Standardize column names by removing suffix
names(rcd) <- names(rcd) %>%
str_replace(paste0(s, "$"), "") %>%
str_replace("mcs_rpt_date$",  "rpt_date") %>%
str_replace("mcs_any_rcd$",   "any_evidence") %>%
str_replace("mcs_perp_rcd$",  "perpetrator") %>%
str_replace("^mcs_(.+)_sev_rcd$", "\\1_sev") %>%
str_replace("^mcs_(.+)_rcd$", "\\1_present")
all_rows[[s]] <- rcd
}
bind_rows(all_rows)
}
df_long <- reshape_to_long(df_wide, 36)
# Drop rows that are entirely empty (no report date and no evidence flag)
# df_long <- df_long %>%
#   filter(!is.na(rpt_date) | !is.na(any_evidence))
# Parse date
df_long <- df_long %>%
mutate(rpt_date = mdy(rpt_date))
cat("Long data dimensions:", nrow(df_long), "rows x", ncol(df_long), "cols\n")
cat("Cases:", n_distinct(df_long$g2id), "\n")
cat("Records per case range:",
min(table(df_long$g2id)), "–", max(table(df_long$g2id)), "\n\n")
# Quick look
glimpse(df_long)
# ===========================================================================
# 2. FURTHER PIVOT: SUBTYPES TO LONG (OPTIONAL ULTRA-LONG FORMAT)
# ===========================================================================
# This creates one row per case × record × subtype, useful for some analyses.
df_ultra_long <- df_long %>%
pivot_longer(
cols = matches("^(pa|sa|ftp|los|em|ml|edu)_(present|sev)$"),
names_to = c("subtype", ".value"),
names_pattern = "^(.+)_(present|sev)$"
) %>%
mutate(
subtype_label = recode(subtype,
pa  = "Physical Abuse",
sa  = "Sexual Abuse",
ftp = "Failure to Protect",
los = "Lack of Supervision",
em  = "Emotional Maltreatment",
ml  = "Medical/Legal",
edu = "Educational Neglect"
)
)
glimpse(df_ultra_long)
# ===========================================================================
# 3. DESCRIPTIVE SUMMARIES
# ===========================================================================
# ---- 3a. Records per case ------------------------------------------------
records_per_case <- df_long %>%
count(g2id, name = "n_records")
cat("\n--- Records per case ---\n")
summary(records_per_case$n_records)
# ---- 3b. Overall prevalence of each subtype (across all records) ----------
prevalence_overall <- df_ultra_long %>%
#filter(!is.na(present)) %>%
group_by(subtype_label) %>%
summarise(
n_records    = n(),
n_present    = sum(present == 1, na.rm = TRUE),
pct_present  = round(100 * n_present / n_records, 1),
.groups = "drop"
) %>%
arrange(desc(pct_present))
cat("\n--- Subtype prevalence (record-level) ---\n")
print(prevalence_overall)
# ---- 3c. Prevalence at the CASE level (ever endorsed across records) ------
case_ever <- df_ultra_long %>%
filter(!is.na(present)) %>%
group_by(g2id, subtype_label) %>%
summarise(ever_present = max(present, na.rm = TRUE), .groups = "drop") %>%
group_by(subtype_label) %>%
summarise(
n_cases      = n_distinct(g2id),
n_ever       = sum(ever_present == 1),
pct_ever     = round(100 * n_ever / n_cases, 1),
.groups = "drop"
) %>%
arrange(desc(pct_ever))
cat("\n--- Subtype prevalence (case-level, ever) ---\n")
print(case_ever)
# ---- 3d. Severity distributions (when present) ---------------------------
df_ultra_long$sev <- as.numeric(df_ultra_long$sev)
severity_dist <- df_ultra_long %>%
filter(present == 1, !is.na(sev)) %>%
group_by(subtype_label) %>%
summarise(
n       = n(),
mean    = round(mean(sev), 2),
sd      = round(sd(sev), 2),
median  = median(sev),
min     = min(sev),
max     = max(sev),
.groups = "drop"
)
cat("\n--- Severity (when subtype present) ---\n")
print(severity_dist)
# ---- 3e. Any-evidence flag distribution -----------------------------------
any_evidence_tab <- df_long %>%
count(any_evidence) %>%
mutate(
label = recode(as.character(any_evidence),
"0" = "No", "1" = "Yes", "2" = "Record present but blank"),
pct = round(100 * n / sum(n), 1)
)
cat("\n--- Any evidence flag ---\n")
print(any_evidence_tab)
# ---- 3f. Co-occurrence: number of subtypes per record --------------------
co_occur <- df_long %>%
rowwise() %>%
mutate(
n_subtypes = sum(c_across(matches("_present$")) == 1, na.rm = TRUE)
) %>%
ungroup()
cat("\n--- Number of subtypes per record ---\n")
print(table(co_occur$n_subtypes))
# ---- 3g. Co-occurrence matrix (case-level) --------------------------------
df_ultra_long$present <- as.numeric(df_ultra_long$present)
case_subtype_matrix <- df_ultra_long %>%
filter(!is.na(present)) %>%
group_by(g2id, subtype_label) %>%
summarise(ever = max(present), .groups = "drop") %>%
pivot_wider(names_from = subtype_label, values_from = ever, values_fill = 0)
# Pairwise co-occurrence counts
subtype_names <- setdiff(names(case_subtype_matrix), "g2id")
co_matrix <- crossprod(as.matrix(case_subtype_matrix[subtype_names]))
cat("\n--- Co-occurrence matrix (case-level) ---\n")
print(co_matrix)
# ---- 3h. Perpetrator frequencies -----------------------------------------
perp_freq <- df_long %>%
filter(!is.na(perpetrator)) %>%
count(perpetrator, sort = TRUE) %>%
mutate(pct = round(100 * n / sum(n), 1))
cat("\n--- Perpetrator frequencies ---\n")
print(perp_freq)
# ---- 3i. Max severity per case across all records -------------------------
case_max_sev <- df_ultra_long %>%
filter(present == 1, !is.na(sev)) %>%
group_by(ID, subtype_label) %>%
summarise(max_sev = max(sev), .groups = "drop") %>%
pivot_wider(names_from = subtype_label, values_from = max_sev)
case_max_sev <- df_ultra_long %>%
filter(present == 1, !is.na(sev)) %>%
group_by(g2id, subtype_label) %>%
summarise(max_sev = max(sev), .groups = "drop") %>%
pivot_wider(names_from = subtype_label, values_from = max_sev)
cat("\n--- Max severity per case (first 10 rows) ---\n")
print(head(case_max_sev, 10))
# ---- 3j. Timeline: records over time -------------------------------------
timeline <- df_long %>%
filter(!is.na(rpt_date)) %>%
mutate(rpt_year = year(rpt_date))
cat("\n--- Records by year ---\n")
print(table(timeline$rpt_year))
# ===========================================================================
# 4. VISUALIZATIONS
# ===========================================================================
# ---- 4a. Records per case histogram --------------------------------------
p1 <- records_per_case %>%
ggplot(aes(x = n_records)) +
geom_histogram(binwidth = 1, fill = "steelblue", color = "white") +
labs(title = "Distribution of Records per Case",
x = "Number of Records", y = "Count of Cases") +
theme_minimal()
print(p1)
ggsave("plot_records_per_case.png", p1, width = 7, height = 5)
# ---- 4b. Subtype prevalence bar chart (case-level) -----------------------
p2 <- case_ever %>%
mutate(subtype_label = fct_reorder(subtype_label, pct_ever)) %>%
ggplot(aes(x = subtype_label, y = pct_ever)) +
geom_col(fill = "tomato") +
geom_text(aes(label = paste0(pct_ever, "%")), hjust = -0.1, size = 3.5) +
coord_flip() +
labs(title = "Maltreatment Subtype Prevalence (Case-Level, Ever)",
x = NULL, y = "% of Cases") +
ylim(0, 100) +
theme_minimal()
print(p2)
ggsave("plot_prevalence_case.png", p2, width = 8, height = 5)
# ---- 4c. Severity distributions (violin + jitter) ------------------------
p3 <- df_ultra_long %>%
filter(present == 1, !is.na(sev)) %>%
ggplot(aes(x = subtype_label, y = sev, fill = subtype_label)) +
geom_violin(alpha = 0.5, show.legend = FALSE) +
geom_jitter(width = 0.15, alpha = 0.3, size = 1, show.legend = FALSE) +
stat_summary(fun = mean, geom = "point", shape = 18, size = 3,
color = "black", show.legend = FALSE) +
labs(title = "Severity Ratings by Subtype (When Present)",
x = NULL, y = "Severity (1 = Least, 5 = Most)") +
coord_flip() +
theme_minimal()
print(p3)
ggsave("plot_severity.png", p3, width = 8, height = 5)
# ---- 4d. Number of subtypes per record -----------------------------------
p4 <- co_occur %>%
ggplot(aes(x = factor(n_subtypes))) +
geom_bar(fill = "mediumpurple") +
labs(title = "Number of Subtypes Endorsed per Record",
x = "Number of Subtypes", y = "Count of Records") +
theme_minimal()
print(p4)
ggsave("plot_n_subtypes.png", p4, width = 7, height = 5)
# ---- 4e. Timeline of reports ---------------------------------------------
p5 <- timeline %>%
count(rpt_year) %>%
ggplot(aes(x = rpt_year, y = n)) +
geom_col(fill = "darkgreen") +
labs(title = "Number of Reports by Year",
x = "Year", y = "Number of Records") +
theme_minimal()
print(p5)
ggsave("plot_timeline.png", p5, width = 7, height = 5)
# ---- 4f. Co-occurrence heatmap -------------------------------------------
co_pct <- co_matrix
diag_vals <- diag(co_pct)
for (i in seq_len(nrow(co_pct))) {
for (j in seq_len(ncol(co_pct))) {
co_pct[i, j] <- round(100 * co_matrix[i, j] / diag_vals[i], 1)
}
}
co_df <- as.data.frame(as.table(co_pct))
names(co_df) <- c("Subtype1", "Subtype2", "Pct")
p6 <- co_df %>%
ggplot(aes(x = Subtype1, y = Subtype2, fill = Pct)) +
geom_tile(color = "white") +
geom_text(aes(label = paste0(Pct, "%")), size = 2.5) +
scale_fill_gradient(low = "white", high = "firebrick") +
labs(title = "Co-occurrence (% of row subtype also having column subtype)",
x = NULL, y = NULL, fill = "% Co-occur") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1, size = 7),
axis.text.y = element_text(size = 7))
print(p6)
ggsave("plot_cooccurrence.png", p6, width = 8, height = 7)
# ===========================================================================
# 5. EXPORT KEY TABLES
# ===========================================================================
# Uncomment to write CSV files of summary tables:
#
# write_csv(df_long,           "mcs_long_format.csv")
# write_csv(df_ultra_long,     "mcs_ultra_long_format.csv")
# write_csv(records_per_case,  "summary_records_per_case.csv")
# write_csv(prevalence_overall,"summary_prevalence_record_level.csv")
# write_csv(case_ever,         "summary_prevalence_case_level.csv")
# write_csv(severity_dist,     "summary_severity.csv")
# write_csv(case_max_sev,      "summary_max_severity_by_case.csv")
# write_csv(perp_freq,         "summary_perpetrators.csv")
cat("\n=== Done! ===\n")
cat("Key objects in your environment:\n")
cat("  df_wide       - original wide data\n")
cat("  df_long       - one row per case × record (17 → standardized cols)\n")
cat("  df_ultra_long - one row per case × record × subtype\n")
cat("  records_per_case, prevalence_overall, case_ever,\n")
cat("  severity_dist, co_matrix, case_max_sev, perp_freq\n")
